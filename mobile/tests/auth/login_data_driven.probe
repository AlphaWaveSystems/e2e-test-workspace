test "login with various credentials"
  @auth @data-driven
  open the app
  tap #nav_login
  wait until "Sign In" appears
  type <email> into #email_field
  type <password> into #password_field
  tap #sign_in_button
  see <expected>

with examples:
  email              password       expected
  "test@test.com"    "password"     "Welcome"
  "admin@test.com"   "admin123"     "Welcome"
  "bad@test.com"     "wrong"        "Invalid credentials"
