test "login with <email> expects <expected>"
  restart the app
  wait 5 seconds
  tap "Login"
  wait 2 seconds
  type "<email>" into #email_field
  type "<password>" into #password_field
  tap #sign_in_button
  wait 2 seconds
  see "<expected>"

with examples:
  email              password     expected
  "test@test.com"    "password"   "Dashboard"
  "admin@test.com"   "admin123"   "Dashboard"
  "wrong@test.com"   "badpass"    "Invalid"
