test "see first item in list"
  restart the app
  wait 5 seconds
  tap "Items"
  wait 2 seconds
  see "Item 0"

test "scroll down and up through items"
  restart the app
  wait 5 seconds
  tap "Items"
  wait 2 seconds
  scroll down
  wait 1 seconds
  scroll down
  wait 1 seconds
  scroll up
  wait 1 seconds

test "search and clear items"
  restart the app
  wait 5 seconds
  tap "Items"
  wait 2 seconds
  type "Item 5" into #search_field
  wait 1 seconds
  clear #search_field
  wait 1 seconds

test "tap FAB add button"
  restart the app
  wait 5 seconds
  tap "Items"
  wait 2 seconds
  tap #fab_add
  wait 1 seconds
  see "Add item tapped"

test "swipe left to delete item"
  restart the app
  wait 5 seconds
  tap "Items"
  wait 2 seconds
  swipe left on #list_item_0
  wait 1 seconds
