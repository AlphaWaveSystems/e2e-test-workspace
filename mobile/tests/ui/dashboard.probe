use "recipes/auth.probe"

test "dashboard shows stats cards"
  @ui @dashboard
  open the app
  log in as "test@test.com" with "password"
  see "Dashboard"
  see "Total Users"
  see "Active Sessions"
  see "Revenue"

test "dashboard ordinal selectors"
  @ui @dashboard
  open the app
  log in as "test@test.com" with "password"
  see 1st "Card"
  see 2nd "Card"
  see 3rd "Card"
  tap 1st "Card"
  see "Details"
  go back

test "dashboard refresh"
  @ui @dashboard
  open the app
  log in as "test@test.com" with "password"
  see "Dashboard"
  tap #refresh_button
  wait until "Loading" disappears
  see "Dashboard"
  see "Total Users"

test "dashboard scroll to bottom"
  @ui @dashboard
  open the app
  log in as "test@test.com" with "password"
  scroll down
  scroll down
  see "Recent Activity"
  scroll up
  see "Total Users"
