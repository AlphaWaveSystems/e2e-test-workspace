test "double tap increments counter"
  restart the app
  wait 5 seconds
  tap "Gestures"
  wait 2 seconds
  see "Double taps: 0"
  double tap #double_tap_area
  wait 2 seconds
  see "Double taps: 1"

test "long press shows context menu"
  restart the app
  wait 5 seconds
  tap "Gestures"
  wait 2 seconds
  long press #long_press_area
  wait 2 seconds
  see "Copy"
  see "Delete"

test "swipe card to dismiss"
  restart the app
  wait 5 seconds
  tap "Gestures"
  wait 2 seconds
  see "Swipe me to dismiss"
  swipe right
  wait 2 seconds

test "drag source to target"
  restart the app
  wait 5 seconds
  tap "Gestures"
  wait 2 seconds
  see "Drag"
  see "Drop"
  drag #drag_source to #drag_target
  wait 2 seconds
