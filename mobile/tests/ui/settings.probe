test "toggle dark mode"
  restart the app
  wait 5 seconds
  tap "Settings"
  wait 2 seconds
  see "Dark Mode"
  tap #dark_mode_toggle
  wait 1 seconds
  tap #dark_mode_toggle
  wait 1 seconds

test "toggle notifications"
  restart the app
  wait 5 seconds
  tap "Settings"
  wait 2 seconds
  see "Notifications"
  tap #notifications_toggle
  wait 1 seconds

test "toggle terms checkbox"
  restart the app
  wait 5 seconds
  tap "Settings"
  wait 2 seconds
  see "Agree to Terms"
  tap #terms_checkbox
  wait 1 seconds

test "save button shows snackbar"
  restart the app
  wait 5 seconds
  tap "Settings"
  wait 2 seconds
  tap #save_button
  wait 1 seconds

test "delete account button is visible"
  restart the app
  wait 5 seconds
  tap "Settings"
  wait 2 seconds
  see "Delete Account"

test "build info is displayed"
  restart the app
  wait 5 seconds
  tap "Settings"
  wait 2 seconds
  see "Build: 1.0.42+dev"

test "language dropdown is visible"
  restart the app
  wait 5 seconds
  tap "Settings"
  wait 2 seconds
  see "Language"
