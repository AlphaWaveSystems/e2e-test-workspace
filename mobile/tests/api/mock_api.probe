test "mock GET returns empty users list"
  @api @mock
  when the app calls GET "/api/users"
    respond with 200 and body "[]"
  restart the app
  wait 5 seconds
  tap "API Tests"
  wait 2 seconds
  tap #fetch_users_button
  wait 1 seconds

test "mock POST returns server error"
  @api @mock
  when the app calls POST "/api/posts"
    respond with 500 and body "{\"error\":\"fail\"}"
  restart the app
  wait 5 seconds
  tap "API Tests"
  wait 2 seconds
  tap #create_post_button
  wait 1 seconds
