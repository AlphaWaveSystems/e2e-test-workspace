test "copy and paste text"
  @device @clipboard
  restart the app
  wait 5 seconds
  scroll down
  wait 1 seconds
  tap "Device"
  wait 2 seconds
  see "Copy this text"
  copy "Hello World" to clipboard
  tap #paste_button
  wait 1 seconds

test "clipboard section elements visible"
  @device @clipboard
  restart the app
  wait 5 seconds
  scroll down
  wait 1 seconds
  tap "Device"
  wait 2 seconds
  see "Clipboard"
  see "Paste"
  see "Text to copy"
