test "allow notification permission"
  @device @permissions
  open the app
  tap #nav_permissions
  allow permission "notifications"
  tap #request_notifications_button
  see "Notifications Enabled"

test "deny camera permission"
  @device @permissions
  open the app
  tap #nav_permissions
  deny permission "camera"
  tap #request_camera_button
  see "Camera Denied"

test "grant all permissions"
  @device @permissions
  open the app
  grant all permissions
  tap #nav_permissions
  see "All Granted"

test "revoke all permissions"
  @device @permissions
  open the app
  grant all permissions
  revoke all permissions
  tap #nav_permissions
  tap #request_camera_button
  see "Camera Denied"
