test "permissions UI elements visible"
  @device @permissions
  restart the app
  wait 5 seconds
  scroll down
  wait 1 seconds
  tap "Device"
  wait 2 seconds
  see "Permissions"
  see "Request Camera"
  see "Request Location"

test "grant all permissions"
  @device @permissions
  restart the app
  wait 5 seconds
  grant all permissions

test "revoke all permissions"
  @device @permissions
  restart the app
  wait 5 seconds
  revoke all permissions
