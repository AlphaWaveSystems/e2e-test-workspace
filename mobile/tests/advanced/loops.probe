test "repeat tap 5 times on dynamic screen"
  restart the app
  wait 5 seconds
  scroll down
  wait 1 seconds
  tap "Dynamic"
  wait 2 seconds
  see "Tapped: 0"
  repeat 5 times
    tap #repeat_action
    wait 1 seconds
  see "Tapped: 5"

test "repeat scroll 3 times in items list"
  restart the app
  wait 5 seconds
  tap "Items"
  wait 2 seconds
  repeat 3 times
    scroll down
    wait 1 seconds
