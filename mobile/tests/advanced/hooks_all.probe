before all
  open the app
  log "suite setup complete"

after all
  take a screenshot called "suite_final"
  log "suite teardown complete"

on failure
  take a screenshot called "failure"
  dump the widget tree

test "hooks test navigate to Dashboard"
  restart the app
  wait 5 seconds
  tap "Dashboard"
  wait 2 seconds
  see "Dashboard"

test "hooks test navigate to Settings"
  restart the app
  wait 5 seconds
  tap "Settings"
  wait 2 seconds
  see "Settings"

test "hooks test navigate to Items"
  restart the app
  wait 5 seconds
  tap "Items"
  wait 2 seconds
  see "Items"
