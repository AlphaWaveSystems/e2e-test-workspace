test "A/B banner conditional"
  restart the app
  wait 5 seconds
  scroll down
  wait 1 seconds
  tap "Dynamic"
  wait 2 seconds
  if "Special Offer!" appears then tap "Special Offer!"
  else see "Dynamic"
  see "Dynamic"

test "error dialog conditional"
  restart the app
  wait 5 seconds
  scroll down
  wait 1 seconds
  tap "Dynamic"
  wait 2 seconds
  tap #trigger_error
  wait 1 seconds
  if "Error" appears then tap "OK"
  else see "Dynamic"
