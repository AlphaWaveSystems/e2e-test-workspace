test "random email and name in login fields"
  restart the app
  wait 5 seconds
  tap "Login"
  wait 2 seconds
  type "<random.email>" into #email_field
  type "<random.name>" into #password_field
  tap #sign_in_button
  wait 2 seconds
  see "Invalid"

test "random number and text in login fields"
  restart the app
  wait 5 seconds
  tap "Login"
  wait 2 seconds
  type "<random.number(1,100)>" into #email_field
  type "<random.text(8)>" into #password_field
  tap #sign_in_button
  wait 2 seconds
  see "Invalid"

test "random uuid and phone in login fields"
  restart the app
  wait 5 seconds
  tap "Login"
  wait 2 seconds
  type "<random.uuid>" into #email_field
  type "<random.phone>" into #password_field
  tap #sign_in_button
  wait 2 seconds
  see "Invalid"
